@media (max-width: 991px) {
  .hero {
    &__container {
      grid-template-columns: 1fr;
    }

    &__banner {
      min-height: 20rem;
    }
  }
}

@media (max-width: 575px) {
  .hero {
    &__title {
      font-size: 1.25rem;
    }

    &__media {
      flex-direction: column;
      align-items: center;
      min-height: auto;
    }

    &__badges {
      padding-top: 0;
    }

    &__footer {
      flex-direction: column;
      align-items: stretch;
    }

    &__btn {
      width: 100%;
    }

    &__prices {
      align-items: flex-start;
    }
  }
}












.hero {
  &__container {
    max-width: 81rem;
    margin: 0 auto;
    padding: 0 1rem;
    @include flex(space-between, stretch, 1rem);
  }

  &__banner {
    flex: 1 1 auto;
    min-width: 0;
    max-height: 25.75rem;
    border-radius: 1.25rem;
    overflow: hidden;
    background: #e9e9e9;
  }

  &__banner-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  &__card {
    flex: 0 0 22.5rem;
    background: #fff;
    border: 0.125rem solid #e30613;
    border-radius: 1.25rem;
    overflow: hidden;
    @include flex(flex-start, stretch, 0, column);
  }

  &__head {
    background: #e30613;
    padding: 1rem 1.25rem;
  }

  &__title {
    margin: 0;
    color: #fff;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
  }

  &__body {
    padding: 1rem 1.25rem 1.25rem;
    flex: 1;
    @include flex(flex-start, stretch, 0, column);
  }

  &__category {
    margin-bottom: 0.5rem;
    color: #8d8d8d;
    font-size: 0.9375rem;
    line-height: 1.2;
  }

  &__name {
    margin: 0 0 1rem;
    color: #111;
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.45;
    max-width: 17.5rem;
  }

  &__media {
    margin-bottom: auto;
    min-height: 14rem;
    @include flex(center, flex-start, 0.875rem);
  }

  &__img {
    width: 10.625rem;
    max-width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  &__badges {
    padding-top: 0.75rem;
    @include flex(flex-start, center, 0.875rem, column);
  }

  &__discount {
    width: 4.25rem;
    height: 4.25rem;
    border-radius: 50%;
    background: #e30613;
    color: #fff;
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1;
    @include flex(center, center);
  }

  &__tags {
    @include flex(flex-start, stretch, 0.625rem, column);
  }

  &__stock,
  &__sale {
    min-height: 2rem;
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.2;
    white-space: nowrap;
    @include flex(center, center);
  }

  &__stock {
    color: #1696f2;
    border: 0.0625rem solid #1696f2;
    background: #f4faff;
  }

  &__sale {
    color: #e30613;
    border: 0.0625rem solid #e30613;
    background: #fff;
  }

  &__footer {
    margin-top: 1.25rem;
    @include flex(space-between, flex-end, 1rem);
  }

  &__btn {
    min-width: 11.875rem;
    height: 3.25rem;
    padding: 0 1rem;
    border-radius: 0.75rem;
    background: #111;
    color: #fff;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    gap: 0.5rem;
    transition: 0.2s ease;
    @include flex(center, center);

    &:hover {
      opacity: 0.9;
    }
  }

  &__btn-icon {
    font-size: 1.125rem;
    line-height: 1;
  }

  &__prices {
    @include flex(flex-start, flex-end, 0.25rem, column);
  }

  &__old-price {
    color: #8d8d8d;
    font-size: 0.875rem;
    line-height: 1.2;
    text-decoration: line-through;
  }

  &__price {
    color: #111;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.2;
  }
}

